{
  "manifest_version": 3,
  "name": "Vibe Board",
  "version": "1.0",
  "description": "A mood-based, aesthetic new tab dashboard.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "action": {
    "default_icon": "assets/icon.svg"
  },
  "icons": {
    "16": "assets/icon.svg",
    "48": "assets/icon.svg",
    "128": "assets/icon.svg"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
